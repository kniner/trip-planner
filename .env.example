# Cross-device sync (optional). Copy to ".env.local" for local dev, and add the
# same values as GitHub repo secrets for the deployed site. If these are unset,
# the app runs in local-only mode (shared across tabs on one device).

# From your Supabase project: Settings -> Data API / API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Everyone using the same trip id shares one plan. Pick anything hard to guess.
VITE_TRIP_ID=family-trip
